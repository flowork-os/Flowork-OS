# Flowork OS — appliance environment (P0)
# Sourced by the Flowork OpenRC services. No secrets here: API keys are entered
# at runtime via the control panel (Settings), exactly like the main repos.
HOME=/root
FLOWORK_HOME=/root
FLOWORK_AGENT_ADDR=127.0.0.1:1987
FLOWORK_ROUTER_ADDR=127.0.0.1:2402
FLOWORK_UI_URL=http://localhost:1987
XDG_RUNTIME_DIR=/run/user/0
